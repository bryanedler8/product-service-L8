### Get product service health
GET /health
Host: localhost:3002

### Get all products
GET /products
Host: localhost:3002

### Get products by category (Best Buy specific)
GET /products/category/Laptops
Host: localhost:3002

### Get products by category - Audio
GET /products/category/Audio
Host: localhost:3002

### Get products by category - Gaming
GET /products/category/Gaming
Host: localhost:3002

### Add a new laptop product
POST /products
Host: localhost:3002
Content-Type: application/json

{
    "name": "MacBook Pro 14-inch",
    "brand": "Apple",
    "price": 1999.99,
    "description": "The MacBook Pro 14-inch features the powerful M3 chip, 16GB RAM, 512GB SSD, and a stunning Liquid Retina XDR display. Perfect for developers and creative professionals.",
    "category": "Laptops",
    "sku": "APL-MBP14-M3-16-512",
    "quantity_available": 25,
    "image_url": "/images/macbook-pro-14.jpg",
    "specifications": {
        "processor": "Apple M3",
        "ram": "16GB",
        "storage": "512GB SSD",
        "display": "14-inch Liquid Retina XDR",
        "battery_life": "18 hours"
    }
}

### Add a new smartphone product
POST /products
Host: localhost:3002
Content-Type: application/json

{
    "name": "Samsung Galaxy S24 Ultra",
    "brand": "Samsung",
    "price": 1299.99,
    "description": "The Samsung Galaxy S24 Ultra features a 200MP camera, Snapdragon 8 Gen 3 processor, and built-in S Pen. Experience the ultimate Android flagship.",
    "category": "Smartphones",
    "sku": "SAM-S24U-256-12",
    "quantity_available": 50,
    "image_url": "/images/galaxy-s24-ultra.jpg",
    "specifications": {
        "processor": "Snapdragon 8 Gen 3",
        "ram": "12GB",
        "storage": "256GB",
        "display": "6.8-inch Dynamic AMOLED 2X",
        "camera": "200MP Quad Camera",
        "battery": "5000mAh"
    }
}

### Add a new audio product (headphones)
POST /products
Host: localhost:3002
Content-Type: application/json

{
    "name": "Sony WH-1000XM5",
    "brand": "Sony",
    "price": 399.99,
    "description": "Industry-leading noise canceling headphones with exceptional sound quality, 30-hour battery life, and comfortable over-ear design.",
    "category": "Audio",
    "sku": "SNY-WH1000XM5-BLK",
    "quantity_available": 100,
    "image_url": "/images/sony-wh1000xm5.jpg",
    "specifications": {
        "type": "Over-ear",
        "noise_canceling": true,
        "battery_life": "30 hours",
        "wireless": true,
        "bluetooth_version": "5.2"
    }
}

