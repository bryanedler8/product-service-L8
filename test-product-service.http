### Add a TV product
POST /products
Host: localhost:3002
Content-Type: application/json

{
    "name": "LG C3 OLED 65-inch",
    "brand": "LG",
    "price": 2499.99,
    "description": "The LG C3 OLED evo 4K TV features self-lit pixels for perfect black, infinite contrast, and the a9 Gen6 AI processor.",
    "category": "TVs",
    "sku": "LG-C3-65-OLED",
    "quantity_available": 10,
    "image_url": "/images/lg-c3-oled.jpg",
    "specifications": {
        "size": "65-inch",
        "display_type": "OLED evo",
        "resolution": "4K",
        "refresh_rate": "120Hz",
        "hdmi_ports": 4,
        "hdr": "Dolby Vision, HDR10"
    }
}

### Update product inventory (add stock)
PUT /products/1/inventory
Host: localhost:3002
Content-Type: application/json

{
    "quantity_change": 10
}

### Update product inventory (remove stock - sell)
PUT /products/1/inventory
Host: localhost:3002
Content-Type: application/json

{
    "quantity_change": -1
}

### Check inventory for a product
GET /products/1/inventory
Host: localhost:3002

### Get specific product by ID
GET /products/1
Host: localhost:3002

### Update product details
PUT /products/1
Host: localhost:3002
Content-Type: application/json

{
    "id": 1,
    "name": "MacBook Pro 14-inch (M3 Pro)",
    "brand": "Apple",
    "price": 2499.99,
    "description": "The MacBook Pro 14-inch features the powerful M3 Pro chip, 18GB RAM, 1TB SSD, and a stunning Liquid Retina XDR display.",
    "category": "Laptops",
    "sku": "APL-MBP14-M3PRO-18-1TB",
    "in_stock": true,
    "quantity_available": 20,
    "image_url": "/images/macbook-pro-14.jpg",
    "rating": 4.9,
    "specifications": {
        "processor": "Apple M3 Pro",
        "ram": "18GB",
        "storage": "1TB SSD",
        "display": "14-inch Liquid Retina XDR",
        "battery_life": "18 hours"
    }
}

### Delete product by ID
DELETE /products/1
Host: localhost:3002

### Get AI service health
GET /ai/health
Host: localhost:3002

### Get product description from AI service
POST /ai/generate/description
Host: localhost:3002
Content-Type: application/json

{
    "name": "Gaming Laptop with RTX 4080",
    "tags": ["gaming", "laptop", "high-performance", "nvidia"]
}

### Get product image from AI service
POST /ai/generate/image
Host: localhost:3002
Content-Type: application/json

{
    "name": "4K Gaming Monitor",
    "description": "32-inch 4K gaming monitor with 144Hz refresh rate, 1ms response time, and NVIDIA G-SYNC compatibility."
}

### Test validation - Invalid SKU format (should fail)
POST /products
Host: localhost:3002
Content-Type: application/json

{
    "name": "Test Product",
    "brand": "Test Brand",
    "price": 99.99,
    "description": "This is a test product with invalid SKU",
    "category": "Electronics",
    "sku": "invalid",
    "quantity_available": 10,
    "image_url": "/test.jpg",
    "specifications": {}
}

